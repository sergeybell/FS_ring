UM; EQ 0.5 Lf A; {Lf} SMAPS 99 MAPARR SPNRARR;

UM; EQ 0.5 Lfs A; {Lfs} SMAPS 100 MAPARR SPNRARR;
UM; DL 0.25; {OD1} SMAPS 101 MAPARR SPNRARR;
UM; DL 0.15; {SDP} SMAPS 102 MAPARR SPNRARR;
UM; DL 0.25; {OD2} SMAPS 103 MAPARR SPNRARR;
UM; DL 4.685; {OR1} SMAPS 104 MAPARR SPNRARR;
