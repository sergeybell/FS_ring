UM; DL 0.25; {OD1} SMAPS 53 MAPARR SPNRARR;
UM; EQ 0.5 Ld A; {Ld} SMAPS 54 MAPARR SPNRARR;
UM; EQ 0.5 Ld A; {Ld} SMAPS 55 MAPARR SPNRARR;
UM; DL 0.25; {OD1} SMAPS 56 MAPARR SPNRARR;
UM; DL 0.15; {SDP} SMAPS 57 MAPARR SPNRARR;
UM; DL 0.25; {OD2} SMAPS 58 MAPARR SPNRARR;
UM; ED 4.685 EBE 0; {R1} SMAPS 59 MAPARR SPNRARR;
UM; DL 0.25; {OD2} SMAPS 60 MAPARR SPNRARR;
UM; DL 0.15; {BPM} SMAPS 61 MAPARR SPNRARR;
UM; DL 0.25; {OD1} SMAPS 62 MAPARR SPNRARR;
UM; EQ 0.5 Lf A; {Lf} SMAPS 63 MAPARR SPNRARR;

UM; EQ 0.5 Lf A; {Lf} SMAPS 64 MAPARR SPNRARR;
UM; DL 0.25; {OD1} SMAPS 65 MAPARR SPNRARR;
UM; DL 0.15; {SFP} SMAPS 66 MAPARR SPNRARR;
