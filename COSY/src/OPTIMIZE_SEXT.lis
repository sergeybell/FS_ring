  11022     WRITE 6 'SGy2 := '&ST(SGY2)&';';
  11023     FIT SGX1 SGY1 SGX2;
  11024       LATTICE SGX1 SGY1 SGX2 SGY2 EB1 1; %LATTICE:10692
  11025       TSS MU NBAR 0; %TSS: 4289
