  11047     WRITE 6 'quadKx :='&ST(QUADKX)&';';
  11048     WRITE 6 'quadKy :='&ST(QUADKY)&';';
  11049     WRITE 6 'quadKz :='&ST(QUADKZ)&';';
  11050     WRITE 6 'MU0 = '&ST(MU0)&';';
