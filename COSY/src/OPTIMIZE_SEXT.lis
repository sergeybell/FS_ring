 --- BIN FILE READ: seq_dFS
  10938 INCLUDE 'seq_dFS';
  10939   PROCEDURE OPTIMIZE_CHROM SEXTGX1 SEXTGY1 SEXTGX2 SEXTGY2 EBE;
  10940     VARIABLE MU 800;
  10941     VARIABLE NBAR 800 3;
  10942     VARIABLE OBJ1 1;
  10943     VARIABLE OBJ2 1;
  10944     VARIABLE OBJ 1;
  10945     VARIABLE SGX1 1;
  10946     VARIABLE SGY1 1;
  10947     VARIABLE SGX2 1;
  10948     VARIABLE SGY2 1;
  10949     VARIABLE EB1 1;
  10950     VARIABLE EB2 1;
  10951     VARIABLE E1 1;
  10952     VARIABLE GAMMA 1;
  10953     VARIABLE CHROM_X 1;
  10954     VARIABLE CHROM_Y 1;
  10955     VARIABLE CHROM_X_1 1;
  10956     VARIABLE CHROM_Y_1 1;
  10957     VARIABLE QUADKX 1;
  10958     VARIABLE QUADKY 1;
  10959     VARIABLE QUADKZ 1;
  10960     VARIABLE MU0 1;
  10961     VARIABLE MU_TP 800 3;
  10962     WRITE 6 'BEGIN';
  10963     SGX1 := SEXTGX1;
  10964     SGY1 := SEXTGY1;
  10965     EB1 := EBE;
  10966     SGX2 := SEXTGX2;
  10967     SGY2 := SEXTGY2;
  10968     WRITE 6 'SGx1, SGy1, EB1 = '&ST(SGX1)&' '&ST(SGY1)&' '&ST(EB1);
  10969     WRITE 6 'SGx2, SGy2 = '&ST(SGX2)&' '&ST(SGY2);
  10970     GAMMA := 1.143914;
  10971     FIT SGX1 SGY1;
  10972       LATTICE SGX1 SGY1 SGX2 SGY2 EB1 1; %LATTICE:10692
  10973       TP MU_TP; %TP: 3955
  10974       CHROM_X:= (MU_TP(1)|(0&0&0&0&1))*(1+1/GAMMA);
  10975       CHROM_Y:= (MU_TP(2)|(0&0&0&0&1))*(1+1/GAMMA);
  10976       OBJ:= SQRT(SQR(CHROM_X) + SQR(CHROM_Y));
  10977       WRITE 6 'SGx1, SGy1, EB1 = '&ST(SGX1)&' '&ST(SGY1)&' '&ST(EB1);
  10978       WRITE 6 'SGx2, SGy2 = '&ST(SGX2)&' '&ST(SGY2);
  10979       WRITE 6 'CHROM_X, CHROM_Y='&ST(CHROM_X)&' '&ST(CHROM_Y);
  10980       WRITE 6 'OBJ ='&ST(OBJ);
  10981       ENDFIT 1E-5 2000 1 OBJ;
  10982     WRITE 6 '====================================';
  10983     WRITE 6 'SGx1, SGx2, SGy1, SGy2, EB1 = '&ST(SGX1)&' '&ST(SGY1)&' '
                  &ST(EB1);
  10984     WRITE 6 'SGx2, SGy2 = '&ST(SGX2)&' '&ST(SGY2);
  10985     WRITE 6 'CHROM_X, CHROM_Y='&ST(CHROM_X)&' '&ST(CHROM_Y);
  10986     WRITE 6 'OBJ ='&ST(OBJ);
  10987     SEXTGX1 := SGX1;
  10988     SEXTGY1 := SGY1;
  10989     ENDPROCEDURE;
  10990   PROCEDURE OPTIMIZE SEXTGX1 SEXTGY1 SEXTGX2 SEXTGY2 EBE;
  10991     VARIABLE MU 800;
