  11455     LOOP J 1 NUM_ELE;
  11456       MAKEMAP 1 J 1 MAPARR SPNRARR; %MAKEMAP:11347
  11457       DS(J+1):=ME(NUM1,NUM1)*D0+ME(NUM1,NUM2)*DPR0+ ME(NUM1,6)*(1+1/(C
                  ONS(ETA)+1)); %ME:  516 %ME:  516 %ME:  516
  11458       WRITE 800 ST(DS(J+1))&'     '&ST(J);
