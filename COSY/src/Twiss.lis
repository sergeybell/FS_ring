 --- BIN FILE READ: seq_dFS_maps
  11334 INCLUDE 'seq_dFS_maps';
  11335   PROCEDURE PICK INDEX MAPARR SPNRARR;
  11336     VARIABLE I 1;
  11337     VARIABLE J 1;
  11338     LOOP I 1 TWOND;
  11339       MSC(I) := MAPARR(I, INDEX);
  11340       ENDLOOP;
  11341     LOOP I 1 3;
  11342       LOOP J 1 3;
  11343         SSCR(I,J) := SPNRARR(I,J,INDEX) + 0*DD(1);
  11344         ENDLOOP;
  11345       ENDLOOP;
  11346     ENDPROCEDURE;
  11347   PROCEDURE MAKEMAP FROM TO START MAPARR SPNRARR;
  11348     VARIABLE J 1;
  11349     WRITE 6 '* '&ST(START);
  11350     LMAPS START MAPARR SPNRARR; %LMAPS:10125
  11351     LOOP J (START+1) TO;
  11352       WRITE 6 '**       '&ST(J);
  11353       PICK J MAPARR SPNRARR; %PICK:11335
  11354       LOCSET 0 0 0 0 0 0; %LOCSET: 1114
  11355       UPDATE 1 1; %UPDATE: 1261
  11356       ENDLOOP;
  11357     LOOP J FROM (START-1);
  11358       WRITE 6 '**       '&ST(J);
  11359       PICK J MAPARR SPNRARR; %PICK:11335
  11360       LOCSET 0 0 0 0 0 0; %LOCSET: 1114
  11361       UPDATE 1 1; %UPDATE: 1261
  11362       ENDLOOP;
  11363     ENDPROCEDURE;
  11364   PROCEDURE GETTWISS0 COORD AL0 BET0 GAM0 MAPARR SPNRARR;
  11365     VARIABLE NUM1 1;
  11366     VARIABLE NUM2 1;
  11367     VARIABLE OBJ 1;
  11368     IF COORD='X';
  11369       NUM1:=1;
  11370       NUM2:=2;
  11371       AL0:=0;
  11372       BET0:=20.0;
  11373       GAM0:=1.0/BET0;
  11374       ELSEIF COORD='Y';
  11375       NUM1:=3;
  11376       NUM2:=4;
  11377       AL0:=0;
  11378       BET0:=3;
  11379       GAM0:=1.0/BET0;
  11380       ELSEIF LO(1);
  11381       WRITE 6 'UNKNOWN COORDINATE';
  11382       ENDIF;
  11383     FIT AL0 BET0 GAM0;
  11384       OBJ:= SQR(SQR(ME(NUM1,NUM1))*BET0-2*ME(NUM1,NUM1)*ME(NUM1,NUM2)*
                  AL0+SQR(ME(NUM1,NUM2))*GAM0-BET0); %ME:  516 %ME:  516 %ME: 
                   516 %ME:  516
  11385       OBJ:=OBJ+ SQR(-ME(NUM1,NUM1)*ME(NUM2,NUM1)*BET0+( ME(NUM1,NUM1)*
                  ME(NUM2,NUM2)+ME(NUM1,NUM2)*ME(NUM2,NUM1) )*AL0-ME(NUM1,NUM2
                  )*ME(NUM2,NUM2)*GAM0-AL0); %ME:  516 %ME:  516 %ME:  516 %ME
                  :  516 %ME:  516 %ME:  516 %ME:  516 %ME:  516
  11386       OBJ:=OBJ+ SQR((ME(NUM2,NUM1)^2)*BET0-2*ME(NUM2,NUM1)*ME(NUM2,NUM
                  2)*AL0+(ME(NUM2,NUM2)^2)*GAM0-(1+AL0^2)/BET0)  ; %ME:  516 %
                  ME:  516 %ME:  516 %ME:  516
  11387       ENDFIT 1E-20 5000 1 OBJ;
  11388     ENDPROCEDURE;
  11389   PROCEDURE BETS TAG COORD NUM_ELE AL0 BET0 GAM0 BETS MAPARR SPNRARR;
  11390     VARIABLE J 1;
  11391     VARIABLE NUM1 1;
  11392     VARIABLE NUM2 1;
  11393     IF COORD='X';
  11394       NUM1:=1;
  11395       NUM2:=2;
  11396       ELSEIF COORD='Y';
  11397       NUM1:=3;
  11398       NUM2:=4;
  11399       ELSEIF LO(1);
  11400       WRITE 6 'UNKNOWN COORDINATE';
  11401       ENDIF;
  11402     UM; %UM: 1488
  11403     BETS(1):=BET0;
  11404     OPENF 800 TAG 'REPLACE';
  11405     WRITE 800 ST(BETS(1))&'     '&ST(0);
  11406     LOOP J 1 NUM_ELE;
  11407       MAKEMAP 1 J 1 MAPARR SPNRARR; %MAKEMAP:11347
  11408       BETS(J+1):=(ME(NUM1,NUM1)^2)*BET0-2*ME(NUM1,NUM1)*ME(NUM1,NUM2)*
                  AL0+(ME(NUM1,NUM2)^2)*GAM0; %ME:  516 %ME:  516 %ME:  516 %M
                  E:  516
  11409       WRITE 800 ST(BETS(J+1))&'     '&ST(J);
  11410       UM; %UM: 1488
  11411       ENDLOOP;
  11412     CLOSEF 800;
  11413     ENDPROCEDURE;
  11414   PROCEDURE GETDISP0 COORD D0 DPR0 MAPARR SPNRARR;
  11415     VARIABLE NUM1 1;
  11416     VARIABLE NUM2 1;
  11417     VARIABLE OBJ 1;
  11418     IF COORD='X';
  11419       NUM1:=1;
  11420       NUM2:=2;
  11421       D0:=0;
  11422       DPR0:=0;
  11423       ELSEIF COORD='Y';
  11424       NUM1:=3;
  11425       NUM2:=4;
  11426       D0:=0;
  11427       DPR0:=0;
  11428       ELSEIF LO(1);
  11429       WRITE 6 'UNKNOWN COORDINATE';
  11430       ENDIF;
  11431     FIT D0 DPR0;
  11432       OBJ:= SQR(  ME(NUM1,NUM1)*D0+ME(NUM1,NUM2)*DPR0+ME(NUM1,6)*(1+1/
                  (CONS(ETA)+1))-D0  ); %ME:  516 %ME:  516 %ME:  516
  11433       OBJ:=OBJ+ SQR(  ME(NUM2,NUM1)*D0+ME(NUM2,NUM2)*DPR0+ME(NUM2,6)*(
                  1+1/(CONS(ETA)+1))-DPR0  )  ; %ME:  516 %ME:  516 %ME:  516
  11434       ENDFIT 1E-20 5000 1 OBJ;
  11435     WRITE 6 'DISP'&COORD&'0' 'DISP_PRIME'&COORD&'0';
  11436     WRITE 6 D0 DPR0;
  11437     ENDPROCEDURE;
  11438   PROCEDURE DISPS TAG COORD NUM_ELE D0 DPR0 DS MAPARR SPNRARR;
  11439     VARIABLE J 1;
