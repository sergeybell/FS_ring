  10663     RESTMASSMEV := RESTMASSAMU*AMUMEV;
  10664     BETA := SQRT(GAMMA*GAMMA - 1)/GAMMA;
  10665     EKIN := (GAMMA-1)*RESTMASSMEV;
  10666     RP EKIN RESTMASSAMU 1; %RP: 6326
  10667     RPS 1 -.142987; %RPS: 6403
  10668     WRITE 6 '++++++++++ SETTING UP FOR DEUTERONS:';
  10669     WRITE 6 'EKIN [MeV]          GAMMA          BETA';
  10670     WRITE 6 SF(EKIN, '(F15.7)')&SF(GAMMA, '(F15.7)')&SF(BETA, '(F15.7)
                  '); %SF:  285 %SF:  285 %SF:  285
  10671     WRITE 6 '+++++++++++++++++++++++++++++++++++';
  10672     ENDPROCEDURE;
  10673   PROCEDURE SET_FOR_DEUTERONS_CHROM Y;
  10674     VARIABLE RESTMASSAMU 1;
  10675     VARIABLE RESTMASSMEV 1;
  10676     VARIABLE EKIN 1;
  10677     VARIABLE GAMMA 1;
  10678     VARIABLE BETA 1;
  10679     GAMMA := Y;
  10680     RESTMASSAMU := 2.01410;
  10681     RESTMASSMEV := RESTMASSAMU*AMUMEV;
  10682     BETA := SQRT(GAMMA*GAMMA - 1)/GAMMA;
  10683     EKIN := (GAMMA-1)*RESTMASSMEV;
  10684     RP EKIN*PARA(1) RESTMASSAMU 1; %RP: 6326 %PARA: 1044
  10685     RPS 1 -.142987; %RPS: 6403
