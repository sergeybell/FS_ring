 --- BIN FILE READ: elements
  10627 INCLUDE 'elements';
  10628   FUNCTION FACCLEN DUMMY;
  10629     FACCLEN := 503;
  10630     ENDFUNCTION;
  10631   FUNCTION FEKIN MOM         RESTMASS      ;
  10632     FEKIN := SQRT(SQR(MOM) + SQR(RESTMASS)) - RESTMASS;
  10633     ENDFUNCTION;
  10634   FUNCTION FMOM EKIN       RESTMASS      ;
  10635     FMOM := SQRT(SQR(EKIN)+2*EKIN*RESTMASS);
  10636     ENDFUNCTION;
  10637   PROCEDURE SET_FOR_PROTONS Y;
  10638     VARIABLE RESTMASSAMU 1;
  10639     VARIABLE RESTMASSMEV 1;
  10640     VARIABLE EKIN 1;
  10641     VARIABLE GAMMA 1;
  10642     VARIABLE BETA 1;
  10643     GAMMA := Y;
  10644     RESTMASSAMU := 1.00728;
  10645     RESTMASSMEV := RESTMASSAMU*AMUMEV;
  10646     BETA := SQRT(GAMMA*GAMMA - 1)/GAMMA;
  10647     EKIN := (GAMMA-1)*RESTMASSMEV;
  10648     RP EKIN RESTMASSAMU 1; %RP: 6326
  10649     RPS 1 1.792847; %RPS: 6403
  10650     WRITE 6 '++++++++++ SETTING UP FOR PROTONS:';
  10651     WRITE 6 'EKIN [MeV]          GAMMA          BETA';
  10652     WRITE 6 SF(EKIN, '(F15.7)')&SF(GAMMA, '(F15.7)')&SF(BETA, '(F15.7)
                  '); %SF:  285 %SF:  285 %SF:  285
  10653     WRITE 6 '+++++++++++++++++++++++++++++++++++';
  10654     ENDPROCEDURE;
  10655   PROCEDURE SET_FOR_DEUTERONS Y;
