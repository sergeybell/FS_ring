STRRING1: Subroutine
Use, RING
!
PRINT,#S/#E
TWISS,save
 !
 ! plot lattice functions versus s
 !
PLOT, TABLE=TWISS, HAXIS=S, VAXIS1=BETX,BETY,&
   VAXIS2=DX, SPLINE, COLOUR=100, RANGE=#S/#E
!
ENDsubroutine
!------------------------------------------------------------------------------------------
Harm: Subroutine
use, RING
harmon
hchromaticity
hvary,    SDP[k2], step=0.00001
hvary,    SFP[k2],  step=0.00001
htune, qx'=-0.00, qy'=-0.00
!
hresonance, order = 1
hresonance, order = 2
hresonance, order = 3
hresonance, order = 4
hresonance, order = 5
TWISS,deltap=0.0, save
!
endharm
